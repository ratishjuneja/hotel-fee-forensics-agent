# Copy to .env.local. Base URL of the FeeForensics API (Person A's Fastify server).
# NEXT_PUBLIC_ is required so the browser bundle can read it for client-side fetches,
# and it is INLINED AT BUILD TIME — you must rebuild the frontend after changing it.
#
# Local dev: point at the local API.
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
#
# Deployed (recommended): leave this UNSET and proxy /api/* on the frontend host
# to the backend. The browser then calls the API same-origin (relative /api/...),
# which inherits HTTPS and avoids mixed-content + CORS. Only set an absolute URL
# here if the API lives on a different, browser-reachable HTTPS origin.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
