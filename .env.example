# FeeForensics environment variables.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# --- Vultr Serverless Inference (REQUIRED — core path) ---
# The API key + base URL come from your Serverless Inference subscription's
# Overview tab. BASE_URL is the /v1 root (no trailing slash). Must be https://
# (http is rejected except for a localhost proxy) so the Bearer key is never
# sent in plaintext.
VULTR_INFERENCE_API_KEY=
VULTR_INFERENCE_BASE_URL=https://api.vultrinference.com/v1
# THE pipeline model (hackathon requirement): a VultronRetriever flavor served
# on Vultr's /v1/rerank endpoint. All retrieval steps (trace steps 2, 3, and
# the step-7 re-retrieval loop) score document chunks on this model — it
# retrieves, it cannot chat. Everything else in the audit pipeline is
# deterministic code, so this is the ONLY model the agent calls.
# Recommended: vultr/VultronRetrieverPrime-Qwen3.5-8B (ids as returned by
# GET /v1/models, org prefix included). Unset → run-audit returns 503.
VULTR_INFERENCE_RETRIEVER_MODEL=
# Optional chat model — NOT used by the audit pipeline. The chatComplete client
# exists for ad-hoc experiments/stretch goals only.
VULTR_INFERENCE_MODEL=

# --- Vultr Object Storage (stretch — document uploads) ---
VULTR_OBJECT_STORAGE_ENDPOINT=
VULTR_OBJECT_STORAGE_ACCESS_KEY=
VULTR_OBJECT_STORAGE_SECRET_KEY=

# --- Vultr Managed PostgreSQL (stretch — case metadata) ---
DATABASE_URL=

# --- Runtime ---
NODE_ENV=development
# API bind host. Defaults to 127.0.0.1 (loopback). Set to 0.0.0.0 to expose the
# API on the deployment VM — do that ONLY behind a firewall / TLS reverse proxy.
# HOST=0.0.0.0
# Comma-separated allowed CORS origins for the web app (defaults to localhost:3000).
# CORS_ORIGIN=https://your-demo-domain
