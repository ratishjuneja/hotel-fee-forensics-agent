# FeeForensics environment variables.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# --- Vultr Serverless Inference (REQUIRED — core path) ---
# OpenAI-compatible API. BASE_URL is the /v1 root (no trailing slash); the client
# appends /chat/completions. Must be https:// (http is rejected except for a
# localhost proxy) so the Bearer key is never sent in plaintext. The agent's core
# reasoning AND document retrieval both run on a VultronRetriever model served here
# (set MODEL to that model id, e.g. a VultronRetriever* flavor for your account).
VULTR_INFERENCE_API_KEY=
VULTR_INFERENCE_BASE_URL=https://api.vultrinference.com/v1
VULTR_INFERENCE_MODEL=

# --- Vultr Object Storage (stretch — document uploads) ---
VULTR_OBJECT_STORAGE_ENDPOINT=
VULTR_OBJECT_STORAGE_ACCESS_KEY=
VULTR_OBJECT_STORAGE_SECRET_KEY=

# --- Vultr Managed PostgreSQL (stretch — case metadata) ---
DATABASE_URL=

# --- Runtime ---
NODE_ENV=development
# API bind host. Defaults to 127.0.0.1 (loopback). Set to 0.0.0.0 to expose the
# API on the deployment VM — do that ONLY behind a firewall / TLS reverse proxy.
# HOST=0.0.0.0
# Comma-separated allowed CORS origins for the web app (defaults to localhost:3000).
# CORS_ORIGIN=https://your-demo-domain
