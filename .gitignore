# Environment / secrets — NEVER commit
# Ignore every .env variant (.env, .env.local, .env.production, .env.development, …)
# but keep the committed example templates.
.env
.env.*
!.env.example
!.env.local.example
*.pem
*.key

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/

# Python (if FastAPI backend is used)
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.pytest_cache/

# Build output
.next/
out/
dist/
build/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test / coverage
coverage/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
